{
    "listen_port": 8080,
    "backend": "http://localhost:8001",
    "max_idle_conns": 500,
    "max_idle_conns_per_host": 500,
    "flush_interval_ms": 50,
    "idle_conn_timeout_sec": 60,
    "cors": {
        "allowed_origins": ["http://localhost:3000","https://example.com","*"],
        "allowed_methods": [ "GET","POST","PUT","DELETE","OPTIONS"],
        "allowed_headers": ["Content-Type","Authorization"]
    },
    "log": {
        "file_path": "logs/proxy.log",
        "max_size_mb": 10,
        "max_backups": 7,
        "max_age_days": 30,
        "compress": true,
        "note": "If you are containerizing this app, leave file_path empty to log to stdout."
    },
    "cache": {
            "routes" : [
            {
                "path": "/api/products",
                "ttl_sec": 300
            },
            {
                "path": "/api/blogs",
                "ttl_sec": 60,
                "note": "dIf you are not using caching, you can leave the cache array empty or remove it entirely."
            }
        ],
        "capacity":50
    }
}